function setup_suckless() {
    suckless_projects=(
        'dwm'
        'st'
        'dmenu'
    )
    # clone and build suckless
    for suckless in "${suckless_projects[@]}"; do
        mkdir -p "$HOME/.local/src" && cd "$HOME/.local/src"
        if ! [ -d "$suckless" ]; then
            git clone "https://github.com/printfdebugging/$suckless.git"
            cd "$suckless"
            sudo make install
        fi
    done
}

